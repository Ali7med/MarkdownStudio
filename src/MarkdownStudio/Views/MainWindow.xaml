<ui:FluentWindow x:Class="MarkdownStudio.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 xmlns:ctl="clr-namespace:MarkdownStudio.Controls"
                 xmlns:conv="clr-namespace:MarkdownStudio.Converters"
                 xmlns:models="clr-namespace:MarkdownStudio.Models"
                 xmlns:loc="clr-namespace:MarkdownStudio.Localization"
                 Title="Markdown Studio"
                 Width="1280" Height="820"
                 MinWidth="720" MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 Icon="pack://application:,,,/Assets/appicon.ico"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 AllowDrop="True"
                 FlowDirection="{Binding FlowDirection, Source={x:Static loc:Localizer.Instance}}"
                 NumberSubstitution.Substitution="European"
                 Drop="OnFileDrop" DragOver="OnDragOver">

    <ui:FluentWindow.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NullToCollapsed" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </ui:FluentWindow.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Title bar -->
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="Auto" />  <!-- Tabs -->
            <RowDefinition Height="*" />     <!-- Editor | Preview -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ===== Title Bar ===== -->
        <ui:TitleBar Grid.Row="0" Title="Markdown Studio">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/appicon.ico" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.7"
                           Text="{loc:Loc app.subtitle}" />
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="1" Padding="8,6"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <!-- يسار: إجراءات سياقية حسب الوضع (تنزلق أفقياً عند ضيق النافذة) -->
              <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <!-- مفتاح الوضع العام (بارز): تحرير ↔ عرض -->
                    <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Edit24}"
                               Content="{loc:Loc toolbar.edit}" Command="{Binding EnterEditorModeCommand}"
                               Visibility="{Binding IsViewerMode, Converter={StaticResource BoolToVisibility}}"
                               Margin="0,0,10,0" />
                    <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Eye24}"
                               Content="{loc:Loc toolbar.view}" Command="{Binding EnterViewerModeCommand}"
                               Visibility="{Binding IsEditorMode, Converter={StaticResource BoolToVisibility}}"
                               Margin="0,0,10,0" />
                    <Separator Margin="2,4" />

                    <!-- إجراءات مشتركة بين الوضعين -->
                    <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon DocumentAdd24}"
                               Content="{loc:Loc toolbar.new}" Command="{Binding NewDocumentCommand}" Margin="6,0,6,0" />
                    <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon FolderOpen24}"
                               Content="{loc:Loc toolbar.open}" Command="{Binding OpenCommand}" Margin="0,0,6,0" />
                    <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon FolderOpen24}"
                               Content="{loc:Loc toolbar.openFolder}" Command="{Binding OpenFolderCommand}" Margin="0,0,6,0" />
                    <ui:DropDownButton Appearance="Secondary" Icon="{ui:SymbolIcon History24}"
                                       Content="{loc:Loc toolbar.recent}" Margin="0,0,6,0">
                        <ui:DropDownButton.Flyout>
                            <ContextMenu ItemsSource="{Binding RecentFiles}"
                                         DataContext="{Binding PlacementTarget.DataContext,
                                                       RelativeSource={RelativeSource Self}}">
                                <ContextMenu.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding}" />
                                        <Setter Property="Command"
                                                Value="{Binding DataContext.OpenRecentCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                    </Style>
                                </ContextMenu.ItemContainerStyle>
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>
                    <ui:DropDownButton Appearance="Secondary" Icon="{ui:SymbolIcon ArrowExportUp24}"
                                       Content="{loc:Loc toolbar.export}" Margin="0,0,6,0">
                        <ui:DropDownButton.Flyout>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                       RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{loc:Loc export.html}" Command="{Binding ExportHtmlCommand}" />
                                <MenuItem Header="{loc:Loc export.pdf}"  Click="OnExportPdf" />
                                <MenuItem Header="{loc:Loc export.docx}" Command="{Binding ExportDocxCommand}" />
                                <MenuItem Header="{loc:Loc export.txt}"  Command="{Binding ExportTextCommand}" />
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>

                    <!-- خاص بالعارض: إظهار/إخفاء المستكشف للتصفّح -->
                    <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Folder24}"
                               Content="{loc:Loc toolbar.explorer}" Command="{Binding ToggleSidebarCommand}"
                               Visibility="{Binding IsViewerMode, Converter={StaticResource BoolToVisibility}}"
                               Margin="0,0,6,0" />

                    <!-- خاص بالمحرّر: حفظ + لوحات + أوضاع -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsEditorMode, Converter={StaticResource BoolToVisibility}}">
                        <Separator Margin="2,4" />
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Save24}"
                                   Content="{loc:Loc toolbar.save}" Command="{Binding SaveCommand}" Margin="6,0,6,0" />
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon SaveEdit24}"
                                   Content="{loc:Loc toolbar.saveAs}" Command="{Binding SaveAsCommand}" Margin="0,0,6,0" />
                        <Separator Margin="2,4" />
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Folder24}"
                                   ToolTip="{loc:Loc toolbar.explorer}" Command="{Binding ToggleSidebarCommand}" Margin="6,0,6,0" />
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Eye24}"
                                   Content="{loc:Loc toolbar.focus}" Command="{Binding ToggleFocusModeCommand}" Margin="0,0,6,0" />
                        <ToggleButton IsChecked="{Binding IsVisualMode}"
                                   Content="{loc:Loc toolbar.studio}" Padding="10,5" Margin="0,0,6,0" />
                    </StackPanel>
                </StackPanel>
              </ScrollViewer>

              <!-- يمين: إجراءات عامة دائمة -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                <ui:DropDownButton x:Name="ThemeButton" Appearance="Secondary"
                           Icon="{ui:SymbolIcon Color24}" Content="{loc:Loc toolbar.theme}" Margin="0,0,6,0">
                    <ui:DropDownButton.Flyout>
                        <ContextMenu x:Name="ThemeMenu" />
                    </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
                <ui:DropDownButton x:Name="LanguageButton" Appearance="Secondary"
                           Icon="{ui:SymbolIcon LocalLanguage24}" Content="{loc:Loc toolbar.language}" Margin="0,0,6,0">
                    <ui:DropDownButton.Flyout>
                        <ContextMenu x:Name="LanguageMenu" />
                    </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
                <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Sparkle24}"
                           Content="{loc:Loc toolbar.whatsNew}" Click="OnOpenWhatsNew" />
              </StackPanel>
            </Grid>

            <!-- شريط أدوات التحرير المرئي (يظهر في وضع الاستوديو) -->
            <Border x:Name="RichToolbar" Visibility="Collapsed" Margin="0,8,0,0"
                    Padding="6,4" CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="تراجع (Ctrl+Z)"
                               Icon="{ui:SymbolIcon ArrowUndo24}" Click="RtUndo" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="إعادة (Ctrl+Y)"
                               Icon="{ui:SymbolIcon ArrowRedo24}" Click="RtRedo" />
                    <Separator Margin="4,2" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="عريض (Bold)"
                               Icon="{ui:SymbolIcon TextBold24}" Click="RtBold" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="مائل (Italic)"
                               Icon="{ui:SymbolIcon TextItalic24}" Click="RtItalic" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="يتوسّطه خط"
                               Icon="{ui:SymbolIcon TextStrikethrough24}" Click="RtStrike" />
                    <ui:Button Appearance="Transparent" Padding="6,4" Content="&lt;/&gt;"
                               ToolTip="كود سطري" Click="RtInlineCode" />
                    <Separator Margin="4,2" />
                    <ui:Button Appearance="Transparent" Padding="6,4" Content="H1" FontWeight="Bold" ToolTip="عنوان 1" Click="RtH1" />
                    <ui:Button Appearance="Transparent" Padding="6,4" Content="H2" FontWeight="Bold" ToolTip="عنوان 2" Click="RtH2" />
                    <ui:Button Appearance="Transparent" Padding="6,4" Content="H3" FontWeight="Bold" ToolTip="عنوان 3" Click="RtH3" />
                    <ui:Button Appearance="Transparent" Padding="6,4" Content="¶" ToolTip="فقرة" Click="RtParagraph" />
                    <Separator Margin="4,2" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="قائمة نقطية"
                               Icon="{ui:SymbolIcon TextBulletList24}" Click="RtUl" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="قائمة مرقّمة"
                               Icon="{ui:SymbolIcon TextNumberListLtr24}" Click="RtOl" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="قائمة مهام"
                               Icon="{ui:SymbolIcon TaskListLtr24}" Click="RtTaskList" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="زيادة الإزاحة"
                               Icon="{ui:SymbolIcon TextIndentIncreaseLtr24}" Click="RtIndent" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="تقليل الإزاحة"
                               Icon="{ui:SymbolIcon TextIndentDecreaseLtr24}" Click="RtOutdent" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="اقتباس"
                               Icon="{ui:SymbolIcon TextQuote24}" Click="RtQuote" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="كتلة كود"
                               Icon="{ui:SymbolIcon Code24}" Click="RtCode" />
                    <Separator Margin="4,2" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="رابط"
                               Icon="{ui:SymbolIcon Link24}" Click="RtLink" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="إزالة الرابط"
                               Icon="{ui:SymbolIcon LinkDismiss24}" Click="RtUnlink" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="صورة"
                               Icon="{ui:SymbolIcon Image24}" Click="RtImage" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="جدول"
                               Icon="{ui:SymbolIcon Table24}" Click="RtTable" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="خط فاصل"
                               Icon="{ui:SymbolIcon LineHorizontal120}" Click="RtHr" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="إزالة التنسيق"
                               Icon="{ui:SymbolIcon TextClearFormatting24}" Click="RtClear" />
                    <Separator Margin="4,2" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="تصغير الخط"
                               Icon="{ui:SymbolIcon TextFontSize20}" Click="RtFontDown" />
                    <ui:Button Appearance="Transparent" Padding="6" ToolTip="تكبير الخط"
                               Icon="{ui:SymbolIcon TextFontSize24}" Click="RtFontUp" />
                </StackPanel>
              </ScrollViewer>
            </Border>
          </StackPanel>
        </Border>

        <!-- ===== Tabs ===== -->
        <TabControl Grid.Row="2"
                    ItemsSource="{Binding Documents}"
                    SelectedItem="{Binding ActiveDocument, Mode=TwoWay}"
                    BorderThickness="0" Background="Transparent"
                    Padding="0" MinHeight="36">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TabControl}}">
                        <ui:SymbolIcon Symbol="Pin16" FontSize="12" Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsPinned,
                                         Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                        <ui:Button Appearance="Transparent" Padding="4" Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon Dismiss16}"
                                   Command="{Binding DataContext.CloseDocumentCommand,
                                             RelativeSource={RelativeSource AncestorType=TabControl}}"
                                   CommandParameter="{Binding}" />
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{loc:Loc tab.pin}"
                                          Command="{Binding PlacementTarget.Tag.TogglePinCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <Separator />
                                <MenuItem Header="{loc:Loc tab.close}"
                                          Command="{Binding PlacementTarget.Tag.CloseDocumentCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="{loc:Loc tab.closeOthers}"
                                          Command="{Binding PlacementTarget.Tag.CloseOthersCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="{loc:Loc tab.closeAll}"
                                          Command="{Binding PlacementTarget.Tag.CloseAllCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <!-- المحتوى الحقيقي مشترك بالأسفل؛ التبويبات للتبديل فقط. -->
            <TabControl.ContentTemplate>
                <DataTemplate />
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- ===== Sidebar | Editor | Preview ===== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="0" />
                <ColumnDefinition x:Name="SidebarSplitterColumn" Width="Auto" />
                <ColumnDefinition x:Name="EditorColumn" Width="*" MinWidth="200" />
                <ColumnDefinition x:Name="PreviewSplitterColumn" Width="Auto" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <!-- ===== Sidebar: Explorer + Outline ===== -->
            <Border x:Name="Sidebar" Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="200" MinHeight="80" />
                    </Grid.RowDefinitions>

                    <!-- Explorer header -->
                    <Grid Grid.Row="0" Margin="10,8,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc explorer.title}" FontWeight="SemiBold" FontSize="12"
                                   Opacity="0.8" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button Appearance="Transparent" Padding="4" ToolTip="{loc:Loc explorer.newFile}"
                                       Icon="{ui:SymbolIcon DocumentAdd20}"
                                       Command="{Binding NewFileInCommand}"
                                       CommandParameter="{Binding WorkspaceRoot}" />
                            <ui:Button Appearance="Transparent" Padding="4" ToolTip="{loc:Loc explorer.newFolder}"
                                       Icon="{ui:SymbolIcon FolderAdd20}"
                                       Command="{Binding NewFolderInCommand}"
                                       CommandParameter="{Binding WorkspaceRoot}" />
                            <ui:Button Appearance="Transparent" Padding="4" ToolTip="{loc:Loc explorer.refresh}"
                                       Icon="{ui:SymbolIcon ArrowClockwise20}"
                                       Command="{Binding RefreshItemCommand}"
                                       CommandParameter="{Binding WorkspaceRoot}" />
                        </StackPanel>
                    </Grid>

                    <!-- Explorer tree / empty -->
                    <Grid Grid.Row="1">
                        <TextBlock Text="{loc:Loc explorer.empty}" Opacity="0.5" FontSize="12"
                                   Margin="12,6" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkspaceRoot}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TreeView x:Name="ExplorerTree"
                                  ItemsSource="{Binding WorkspaceRoot.Children}"
                                  BorderThickness="0" Background="Transparent"
                                  MouseDoubleClick="OnExplorerDoubleClick"
                                  KeyDown="OnExplorerKeyDown">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:FileSystemItem}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <ui:SymbolIcon Margin="0,0,6,0" FontSize="16">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Symbol" Value="Document24" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Symbol" Value="Folder24" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <!-- الاسم أو حقل إعادة التسمية -->
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding Name, Mode=OneWay}" MinWidth="120"
                                                 Tag="{Binding}" KeyDown="OnRenameKeyDown"
                                                 LostFocus="OnRenameLostFocus" Loaded="OnRenameBoxLoaded">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                        </Style>
                                    </HierarchicalDataTemplate.ItemContainerStyle>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{loc:Loc explorer.newFile}" Command="{Binding NewFileInCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="{loc:Loc explorer.newFolder}" Command="{Binding NewFolderInCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="{loc:Loc explorer.rename}" Click="OnRenameMenu" />
                                    <MenuItem Header="{loc:Loc explorer.duplicate}" Command="{Binding DuplicateItemCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="{loc:Loc explorer.delete}" Command="{Binding DeleteItemCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="{loc:Loc explorer.copyPath}" Click="OnCopyPathMenu" />
                                    <MenuItem Header="{loc:Loc explorer.reveal}" Click="OnRevealMenu" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                        </TreeView>
                    </Grid>

                    <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center" ResizeBehavior="PreviousAndNext"
                                  Background="{DynamicResource ControlElevationBorderBrush}" />

                    <!-- Outline header -->
                    <TextBlock Grid.Row="3" Text="{loc:Loc outline.title}" FontWeight="SemiBold" FontSize="12"
                               Opacity="0.8" Margin="10,6,0,4" />

                    <!-- Outline tree -->
                    <TreeView x:Name="OutlineTree" Grid.Row="4"
                              ItemsSource="{Binding Outline}"
                              BorderThickness="0" Background="Transparent"
                              SelectedItemChanged="OnOutlineSelected">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:OutlineItem}"
                                                      ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource ControlElevationBorderBrush}" />

            <!-- Editor column: breadcrumb + editor + overlays -->
            <Grid x:Name="EditorPane" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Breadcrumb -->
                <Border Grid.Row="0" Padding="10,4"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        Visibility="{Binding Breadcrumb, Converter={StaticResource NullToCollapsed}}">
                    <TextBlock Text="{Binding Breadcrumb}" FontSize="12" Opacity="0.7"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <Grid Grid.Row="1">
                    <avalonedit:TextEditor x:Name="Editor"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="14"
                                           ShowLineNumbers="True"
                                           WordWrap="True"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"
                                           Background="{DynamicResource ApplicationBackgroundBrush}"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           LineNumbersForeground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Padding="8" />
                    <ctl:FindReplacePanel x:Name="FindPanel" />
                    <ctl:GoToLinePanel x:Name="GoToPanel" />
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource ControlElevationBorderBrush}" />

            <!-- Preview -->
            <Border x:Name="PreviewPane" Grid.Column="4" Background="{DynamicResource ApplicationBackgroundBrush}">
                <wv2:WebView2 x:Name="Preview" />
            </Border>
        </Grid>

        <!-- ===== Welcome / Empty State ===== -->
        <Grid Grid.Row="3" Grid.ColumnSpan="5" Panel.ZIndex="5"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              Visibility="{Binding WelcomeVisibility}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="460">
                <TextBlock Text="{loc:Loc welcome.title}" FontSize="34" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Loc welcome.subtitle}"
                           Opacity="0.7" FontSize="14" Margin="0,6,0,26"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon FolderOpen24}"
                               Content="{loc:Loc welcome.openFile}" Command="{Binding OpenCommand}"
                               Margin="0,0,10,0" MinWidth="150" />
                    <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon DocumentAdd24}"
                               Content="{loc:Loc welcome.newDoc}" Command="{Binding NewDocumentCommand}"
                               MinWidth="150" />
                </StackPanel>

                <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Folder24}"
                           HorizontalAlignment="Center" Margin="0,0,0,28"
                           Content="{loc:Loc welcome.openFolder}" Command="{Binding OpenFolderCommand}" />

                <TextBlock Text="{loc:Loc welcome.recent}" FontWeight="SemiBold" Opacity="0.8"
                           Margin="4,0,0,8"
                           Visibility="{Binding RecentFiles.Count,
                                        Converter={StaticResource CountToVisibility}}" />
                <ItemsControl ItemsSource="{Binding RecentFiles}" MaxHeight="220">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Icon="{ui:SymbolIcon Document24}"
                                       Content="{Binding}"
                                       Command="{Binding DataContext.OpenRecentCommand,
                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                       CommandParameter="{Binding}"
                                       Margin="0,1" Padding="8,6" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{loc:Loc welcome.dragHint}"
                           Opacity="0.5" FontSize="12" Margin="0,18,0,0"
                           HorizontalAlignment="Center" />

                <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Star24}"
                           HorizontalAlignment="Center" Margin="0,14,0,0"
                           Content="{loc:Loc welcome.setDefault}"
                           Command="{Binding SetAsDefaultAppCommand}" />
            </StackPanel>
        </Grid>

        <!-- طبقة تصدير PDF مخفية (WebView2 خارج الشاشة يُنشأ برمجياً) -->
        <Grid x:Name="ExportLayer" Grid.Row="3" Grid.ColumnSpan="5"
              Opacity="0" IsHitTestVisible="False" Panel.ZIndex="-1" />

        <!-- ===== Status Bar ===== -->
        <Border Grid.Row="4" Padding="12,4"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Opacity="0.8" FontSize="12"
                           HorizontalAlignment="Left" />
                <TextBlock Text="{Binding WordCountText}" Opacity="0.7" FontSize="12"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="CaretStatus" HorizontalAlignment="Right"
                           Opacity="0.8" FontSize="12" Text="Ln 1, Col 1" />
            </Grid>
        </Border>

        <!-- ===== Command Palette / Quick Open / Symbols (overlay) ===== -->
        <ctl:CommandPalette x:Name="Palette" Grid.Row="0" Grid.RowSpan="5"
                            Panel.ZIndex="100" />
        <ctl:ProjectSearchPanel x:Name="ProjectSearch" Grid.Row="0" Grid.RowSpan="5"
                                Panel.ZIndex="100" />
    </Grid>
</ui:FluentWindow>
