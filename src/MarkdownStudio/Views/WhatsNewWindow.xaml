<ui:FluentWindow x:Class="MarkdownStudio.Views.WhatsNewWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:MarkdownStudio.Localization"
                 Title="{loc:Loc whatsNew.title}"
                 Width="580" Height="640" MinWidth="420" MinHeight="360"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 FlowDirection="{Binding FlowDirection, Source={x:Static loc:Localizer.Instance}}"
                 NumberSubstitution.Substitution="European">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{loc:Loc whatsNew.title}" />

        <!-- Header: current version -->
        <Border Grid.Row="1" Padding="20,10,20,16">
            <StackPanel>
                <TextBlock Text="{loc:Loc whatsNew.title}" FontSize="24" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="{loc:Loc whatsNew.current}" Opacity="0.7" FontSize="13" />
                    <Border Margin="8,0,0,0" Padding="8,2" CornerRadius="6"
                            Background="{DynamicResource AccentFillColorDefaultBrush}">
                        <TextBlock x:Name="VersionBadge" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,0,20,0">
            <StackPanel x:Name="EntriesHost" />
        </ScrollViewer>

        <Border Grid.Row="3" Padding="20,12"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <ui:Button Content="{loc:Loc whatsNew.close}" Appearance="Primary"
                       HorizontalAlignment="Right" MinWidth="96" Click="OnClose" />
        </Border>
    </Grid>
</ui:FluentWindow>
