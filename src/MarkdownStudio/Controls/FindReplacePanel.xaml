<UserControl x:Class="MarkdownStudio.Controls.FindReplacePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             HorizontalAlignment="Right" VerticalAlignment="Top"
             Margin="0,8,16,0" Visibility="Collapsed">
    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- صف البحث -->
            <ui:TextBox x:Name="FindBox" Grid.Row="0" Grid.Column="0"
                        Width="240" PlaceholderText="بحث…"
                        KeyDown="OnFindBoxKeyDown" TextChanged="OnQueryChanged" />

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
                <ToggleButton x:Name="CaseToggle" Content="Aa" ToolTip="مطابقة حالة الأحرف"
                              Padding="8,4" Margin="0,0,2,0" Click="OnOptionsChanged" />
                <ToggleButton x:Name="WordToggle" Content="⌈ab⌉" ToolTip="كلمة كاملة"
                              Padding="8,4" Margin="0,0,2,0" Click="OnOptionsChanged" />
                <ToggleButton x:Name="RegexToggle" Content=".*" ToolTip="تعبير نمطي (Regex)"
                              Padding="8,4" Click="OnOptionsChanged" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock x:Name="CountLabel" Text="0" VerticalAlignment="Center"
                           Opacity="0.7" FontSize="12" MinWidth="52" TextAlignment="Center" />
                <ui:Button Icon="{ui:SymbolIcon ChevronUp24}" Appearance="Transparent"
                           Padding="6" ToolTip="السابق (Shift+Enter)" Click="OnFindPrev" />
                <ui:Button Icon="{ui:SymbolIcon ChevronDown24}" Appearance="Transparent"
                           Padding="6" ToolTip="التالي (Enter)" Click="OnFindNext" />
                <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                           Padding="6" ToolTip="إغلاق (Esc)" Click="OnClose" />
            </StackPanel>

            <!-- صف الاستبدال -->
            <ui:TextBox x:Name="ReplaceBox" Grid.Row="1" Grid.Column="0"
                        Width="240" Margin="0,6,0,0" PlaceholderText="استبدال بـ…"
                        KeyDown="OnReplaceBoxKeyDown" />
            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="8,6,0,0">
                <ui:Button Content="استبدال" Appearance="Secondary" Padding="8,4"
                           Margin="0,0,4,0" Click="OnReplace" />
                <ui:Button Content="استبدال الكل" Appearance="Secondary" Padding="8,4"
                           Click="OnReplaceAll" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
